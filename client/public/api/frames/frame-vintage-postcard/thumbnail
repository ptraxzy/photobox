<svg xmlns="http://www.w3.org/2000/svg" width="180" height="210" viewBox="0 0 600 700">
      <defs>
        <mask id="hole-mask">
          <rect width="600" height="700" fill="white" /><rect x="40" y="40" width="520" height="520" rx="20" ry="20" fill="black" />
        </mask>
        
      </defs>
      <!-- Base Background Card -->
      <rect width="600" height="700" fill="#eedec9" mask="url(#hole-mask)" />
      
      <!-- Slot outlines (adds a very nice border around punched slots for photo alignment) -->
      <rect x="40" y="40" width="520" height="520" rx="20" ry="20" fill="none" stroke="#7c5c43" stroke-width="4" opacity="0.3" />
      
      <!-- Outer Border -->
      <rect width="600" height="700" fill="none" stroke="#7c5c43" stroke-width="12" />
      
      <!-- Decorations Layer -->
      
      <!-- Vintage stamp print -->
      <g transform="translate(480, 40)" opacity="0.7">
        <rect width="80" height="90" fill="none" stroke="#7c5c43" stroke-width="3" stroke-dasharray="4,4" />
        <rect x="6" y="6" width="68" height="78" fill="none" stroke="#7c5c43" stroke-width="1" />
        <circle cx="40" cy="45" r="20" fill="none" stroke="#7c5c43" stroke-width="1.5" />
        <text x="40" y="49" font-family="'Outfit', sans-serif" font-weight="800" font-size="12" fill="#7c5c43" text-anchor="middle">50c</text>
      </g>
    
      
      <!-- Branding Logo Text -->
      <text x="300" y="680" font-family="'Plus Jakarta Sans', 'Outfit', sans-serif" font-weight="800" font-size="15" fill="#7c5c43" letter-spacing="3" text-anchor="middle">SNAPVIBE ✦ STUDIO</text>
    </svg>